<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:fontFamily="@font/montserrat_semibold"
        android:gravity="center"
        android:text="Зміна email"
        android:textColor="#1A1A2E"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:fontFamily="@font/montserrat_regular"
        android:text="Новий email"
        android:textColor="#4A4A5A"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/editNewEmail"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/input_field_background"
        android:fontFamily="@font/montserrat_regular"
        android:hint="example@email.com"
        android:inputType="textEmailAddress"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#1A1A2E"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/errorNewEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:fontFamily="@font/montserrat_regular"
        android:textColor="#E53935"
        android:textSize="12sp"
        android:visibility="gone" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:layout_marginTop="15dp"
        android:fontFamily="@font/montserrat_regular"
        android:text="Підтвердіть паролем"
        android:textColor="#4A4A5A"
        android:textSize="13sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="52dp">

        <EditText
            android:id="@+id/editPasswordConfirm"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/input_field_background"
            android:fontFamily="@font/montserrat_regular"
            android:hint="Поточний пароль"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="52dp"
            android:textColor="#1A1A2E"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/togglePasswordConfirm"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="14dp"
            android:contentDescription="Toggle password visibility"
            android:src="@drawable/ic_eye_off" />
    </FrameLayout>

    <TextView
        android:id="@+id/errorPasswordConfirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:fontFamily="@font/montserrat_regular"
        android:textColor="#E53935"
        android:textSize="12sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/textError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:fontFamily="@font/montserrat_regular"
        android:textColor="#E53935"
        android:textSize="13sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnConfirmEmailChange"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/button_gradient"
        android:fontFamily="@font/montserrat_semibold"
        android:text="Змінити email"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@null" />

</LinearLayout>