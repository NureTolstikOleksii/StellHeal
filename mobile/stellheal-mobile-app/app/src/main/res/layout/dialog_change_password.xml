<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:fontFamily="@font/montserrat_semibold"
        android:gravity="center"
        android:text="Зміна пароля"
        android:textColor="#1A1A2E"
        android:textSize="18sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="52dp">

        <EditText
            android:id="@+id/editCurrentPassword"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/input_field_background"
            android:fontFamily="@font/montserrat_regular"
            android:hint="Поточний пароль"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="52dp"
            android:textColor="#1A1A2E"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/toggleCurrentPassword"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="14dp"
            android:contentDescription="Toggle current password visibility"
            android:src="@drawable/ic_eye_off" />
    </FrameLayout>

    <TextView
        android:id="@+id/errorCurrentPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/montserrat_regular"
        android:textColor="#E53935"
        android:textSize="12sp"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp">

        <EditText
            android:id="@+id/editNewPassword"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/input_field_background"
            android:fontFamily="@font/montserrat_regular"
            android:hint="Новий пароль"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="52dp"
            android:textColor="#1A1A2E"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/toggleNewPassword"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="14dp"
            android:contentDescription="Toggle new password visibility"
            android:src="@drawable/ic_eye_off" />
    </FrameLayout>

    <ProgressBar
        android:id="@+id/passwordStrengthBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="8dp"
        android:max="4"
        android:progress="0"
        android:progressDrawable="@drawable/password_strength_drawable"
        android:visibility="gone" />

    <TextView
        android:id="@+id/textStrengthLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/montserrat_regular"
        android:gravity="end"
        android:textSize="11sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/errorNewPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/montserrat_regular"
        android:textColor="#E53935"
        android:textSize="12sp"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp">

        <EditText
            android:id="@+id/editConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/input_field_background"
            android:fontFamily="@font/montserrat_regular"
            android:hint="Повторіть новий пароль"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="52dp"
            android:textColor="#1A1A2E"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/toggleConfirmPassword"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="14dp"
            android:contentDescription="Toggle confirm password visibility"
            android:src="@drawable/ic_eye_off" />
    </FrameLayout>

    <TextView
        android:id="@+id/errorConfirmPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/montserrat_regular"
        android:textColor="#E53935"
        android:textSize="12sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/textError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:fontFamily="@font/montserrat_regular"
        android:textColor="#E53935"
        android:textSize="13sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnConfirmChange"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/button_gradient"
        android:fontFamily="@font/montserrat_semibold"
        android:text="Змінити пароль"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@null" />

</LinearLayout>